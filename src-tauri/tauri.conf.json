{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cc-sessions-viewer",
  "version": "0.1.10",
  "identifier": "com.wuchao.cc-sessions-viewer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "features": []
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "width": 1180,
        "height": 760,
        "minWidth": 880,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY0RUIwRjRBOTkyODYwRTgKUldUb1lDaVpTZy9yWkIwbDhNZHBNbER4TWlnSXZKejExVENPZVFVQXhvZysvdit2Njc2cXFZQngK",
      "endpoints": [
        "https://github.com/jerrywu001/cc-sessions-viewer/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
